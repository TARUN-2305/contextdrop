# -----------------------------------------------------------------------------
# React Frontend Client - Environment Configuration Example
# Copy this file to '.env.local' and adjust local service ports if needed.
# -----------------------------------------------------------------------------

# URL of the Django REST API backend (defaults to localhost:8000)
VITE_API_URL=http://localhost:8000

# URL of the Node.js Server-Sent Events (SSE) chat streaming server (defaults to localhost:4000)
VITE_SSE_URL=http://localhost:4000

# URL of the local Vite React application server (defaults to localhost:5173)
VITE_APP_URL=http://localhost:5173

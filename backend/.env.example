# -----------------------------------------------------------------------------
# Django REST API - Environment Configuration Example
# Copy this file to '.env' and fill in your custom credentials.
# -----------------------------------------------------------------------------

# Set to True for local development. Set to False in staging/production.
DEBUG=True

# Connection URL for PostgreSQL. Docker-compose sets up this default user and password.
# Format: postgres://username:password@host:port/database_name
DATABASE_URL=postgres://contextdrop_user:contextdrop_password@localhost:5432/contextdrop

# Allow CORS requests from all origins (True for local development)
CORS_ALLOW_ALL_ORIGINS=True

# -----------------------------------------------------------------------------
# LLM Providers (Groq / Ollama Fallback)
# -----------------------------------------------------------------------------

# Get your API key from https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Local Ollama address (defaults to localhost:11434)
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Embedding Providers (Ollama / OpenAI)
# -----------------------------------------------------------------------------

# Set to 'ollama' to run nomic-embed-text locally, or 'openai' for text-embedding-ada-002 / text-embedding-3-small
EMBEDDING_PROVIDER=ollama

# If EMBEDDING_PROVIDER is 'openai', fill in your OpenAI API Key (leave empty otherwise)
# OpenAI API keys can be generated at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Service-to-Service Authentication
# -----------------------------------------------------------------------------

# Shared secret key used to authenticate requests between the Node SSE server and Django.
# Must match the value in the SSE server configuration. Keep this key secure.
INTERNAL_API_KEY=cd_secret_internal_api_key_5f8e32e9a7c6
